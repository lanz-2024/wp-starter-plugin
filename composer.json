{
	"name": "lanz2024/wp-starter-plugin",
	"description": "WordPress starter plugin demonstrating modern PHP 8.5 + all major WP APIs",
	"type": "wordpress-plugin",
	"license": "MIT",
	"require": {
		"php": "^8.5",
		"psr/container": "^2.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^11",
		"wp-coding-standards/wpcs": "^3",
		"phpstan/phpstan": "^2",
		"szepeviktor/phpstan-wordpress": "^2",
		"brain/monkey": "^2",
		"yoast/phpunit-polyfills": "^2",
		"squizlabs/php_codesniffer": "^3",
		"php-stubs/wordpress-stubs": "^6.4"
	},
	"autoload": {
		"psr-4": {
			"WPStarterPlugin\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"WPStarterPlugin\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"phpcs": "phpcs --standard=WordPress-Extra src/",
		"phpstan": "phpstan analyse src/ --level=8"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
